# ------------------------------------------------------------------
# Monday.com configuration
# ------------------------------------------------------------------
# Personal/API token from monday.com -> Avatar -> Admin -> API
MONDAY_API_TOKEN=your_monday_api_token_here

# Board ID of the "Deals" board (visible in the board's URL)
DEALS_BOARD_ID=1234567890

# Board ID of the "Work Orders" board (visible in the board's URL)
WORKORDERS_BOARD_ID=1234567891

# ------------------------------------------------------------------
# Fireworks AI configuration
# ------------------------------------------------------------------
FIREWORKS_API_KEY=your_fireworks_api_key_here
FIREWORKS_MODEL=accounts/fireworks/models/llama-v3p1-70b-instruct

# ------------------------------------------------------------------
# App configuration
# ------------------------------------------------------------------
# Used by uvicorn when run standalone / used as the internal backend port
PORT=8000

# Used by the Streamlit frontend to reach the FastAPI backend.
# When running both locally in separate terminals, keep this as-is.
BACKEND_URL=http://localhost:8000

LOG_LEVEL=INFO
